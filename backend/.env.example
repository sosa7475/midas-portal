PORT=3001
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# LLM Provider (default: openai — set to 'anthropic' to switch)
ACTIVE_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.5

# Anthropic (used if ACTIVE_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Encryption (for storing user API keys)
ENCRYPTION_KEY=32-char-hex-string-for-aes-256

# Orderly Network
ORDERLY_API_KEY=
ORDERLY_API_SECRET=
ORDERLY_BROKER_ID=midas_portal
ORDERLY_NETWORK_ID=mainnet  # or testnet

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
